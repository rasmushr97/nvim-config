// Repo-managed Zellij config.
// Defaults are used for keybinds and plugin setup unless overridden here.

// Keep first-run noise down when starting new sessions.
show_release_notes false

// Keep pane borders visible; they make splits easier to scan.
pane_frames true

// Store enough scrollback for normal development sessions.
scroll_buffer_size 10000

// Preserve the default mouse behavior explicitly.
mouse_mode true
copy_on_select true
